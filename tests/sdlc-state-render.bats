#!/usr/bin/env bats
# Tests for the markdown view generator subcommand of scripts/sdlc-state.sh
# (Story 4.2-002 — markdown view generator).
#
# These tests pin the rendering contract that the build-stories orchestrator
# and dispatched agents rely on: the SQLite ledger is the source of truth,
# and `.build-progress.md` is a regenerated read-model.
#
# Pattern: every test uses an isolated BATS_TEST_TMPDIR DB so the real
# `.sdlc-state.db` is never touched. The `--db` flag targets the temp DB.

SDLC_STATE="${BATS_TEST_DIRNAME}/../scripts/sdlc-state.sh"
EMIT_HOOK="${BATS_TEST_DIRNAME}/../hooks/sdlc-state-emit.sh"
HISTORICAL="${BATS_TEST_DIRNAME}/../docs/stories/.build-progress.historical.md"

setup() {
    DB="${BATS_TEST_TMPDIR}/test.db"
    "${SDLC_STATE}" --db "${DB}" init >/dev/null
}

# ---------------------------------------------------------------------------
# render: subcommand exists and is wired into usage.
# ---------------------------------------------------------------------------

@test "render subcommand is documented in usage" {
    run "${SDLC_STATE}" --help
    [ "${status}" -eq 0 ]
    [[ "${output}" == *"render"* ]]
}

# ---------------------------------------------------------------------------
# Empty ledger: a well-formed but empty progress doc is still produced.
# ---------------------------------------------------------------------------

@test "render of an empty ledger produces a well-formed empty doc" {
    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # Mandatory shape: heading, auto-gen banner, E2E Gate section.
    [[ "${output}" == *"# Build Progress"* ]]
    [[ "${output}" == *"AUTOGENERATED"* ]]
    [[ "${output}" == *"## E2E Gate"* ]]
}

# ---------------------------------------------------------------------------
# Single run + 3 stories + stage events renders the standard table.
# ---------------------------------------------------------------------------

@test "render of single run with 3 stories produces a build-log table" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    local s
    for s in 4.2-A 4.2-B 4.2-C; do
        "${SDLC_STATE}" --db "${DB}" story-upsert \
            "${run_id}" "${s}" 04 "Story ${s}" P1 3 \
            bash-zsh-macos-engineer "feature/${s}" 100 DONE
    done
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # The Epic-04 section heading must appear.
    [[ "${output}" == *"## Epic-04 Build Log"* ]]
    # Standard table header.
    [[ "${output}" == *"| Story ID | Title | Status | Branch | PR | Started | Completed |"* ]]
    # All three stories appear.
    [[ "${output}" == *"| 4.2-A | Story 4.2-A | DONE | feature/4.2-A | #100 |"* ]]
    [[ "${output}" == *"| 4.2-B | Story 4.2-B | DONE | feature/4.2-B | #100 |"* ]]
    [[ "${output}" == *"| 4.2-C | Story 4.2-C | DONE | feature/4.2-C | #100 |"* ]]
}

# ---------------------------------------------------------------------------
# Multiple runs across multiple epics render with epic-section headers.
# Order: epic-section blocks sorted by epic_id ascending.
# ---------------------------------------------------------------------------

@test "render with multiple epics produces sorted epic sections" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create batch-test parallel)
    # Insert in reverse order to verify deterministic sort.
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 04.X 04 "Epic 4 story" P1 3 bash feature/04.X 1 DONE
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 03.X 03 "Epic 3 story" P1 3 bash feature/03.X 2 DONE
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 01.X 01 "Epic 1 story" P1 3 bash feature/01.X 3 DONE
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # All three epic sections present.
    [[ "${output}" == *"## Epic-01 Build Log"* ]]
    [[ "${output}" == *"## Epic-03 Build Log"* ]]
    [[ "${output}" == *"## Epic-04 Build Log"* ]]
    # And sorted ascending: epic-01 appears before epic-03 which appears before epic-04.
    local pos1 pos3 pos4
    pos1=$(printf '%s' "${output}" | grep -n "## Epic-01 Build Log" | head -1 | cut -d: -f1)
    pos3=$(printf '%s' "${output}" | grep -n "## Epic-03 Build Log" | head -1 | cut -d: -f1)
    pos4=$(printf '%s' "${output}" | grep -n "## Epic-04 Build Log" | head -1 | cut -d: -f1)
    [ "${pos1}" -lt "${pos3}" ]
    [ "${pos3}" -lt "${pos4}" ]
}

# ---------------------------------------------------------------------------
# Failed stories render with FAILED status row.
# ---------------------------------------------------------------------------

@test "render shows FAILED status for failed stories" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-FAIL 04 "Doomed story" P1 3 bash feature/4.2-FAIL "" FAILED
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" FAILED

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    [[ "${output}" == *"FAILED"* ]]
    [[ "${output}" == *"| 4.2-FAIL | Doomed story | FAILED | feature/4.2-FAIL"* ]]
}

# ---------------------------------------------------------------------------
# E2E gate rows render in the E2E Gate section.
# Convention: events with source='e2e-gate' contribute one row per epic,
# message format "<epic>|<result>|<notes>" is read by the renderer.
# ---------------------------------------------------------------------------

@test "E2E gate events render in the E2E Gate section" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" event-log "${run_id}" "" success e2e-gate "04|E2E_PASS|all gates green"
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    [[ "${output}" == *"## E2E Gate"* ]]
    # Row in the gate table.
    [[ "${output}" == *"| 04 | E2E_PASS | all gates green |"* ]]
}

# ---------------------------------------------------------------------------
# Idempotency: rendering twice from the same DB state produces byte-identical
# output. This is the property that makes the markdown a deterministic view.
# ---------------------------------------------------------------------------

@test "render is byte-identical across repeated invocations (idempotent)" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-IDEM 04 "Idempotency check" P1 3 bash feature/4.2-IDEM 9 DONE
    "${SDLC_STATE}" --db "${DB}" event-log "${run_id}" "" success e2e-gate "04|E2E_PASS|stable"
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE

    local out1 out2
    out1="${BATS_TEST_TMPDIR}/render-1.md"
    out2="${BATS_TEST_TMPDIR}/render-2.md"
    "${SDLC_STATE}" --db "${DB}" render >"${out1}"
    "${SDLC_STATE}" --db "${DB}" render >"${out2}"
    # Byte-identical.
    diff "${out1}" "${out2}"
}

# ---------------------------------------------------------------------------
# Deterministic ordering: order of inserts must not affect the output.
# Two databases with the same logical content but different insertion order
# must produce identical markdown.
# ---------------------------------------------------------------------------

@test "render output is stable regardless of story insertion order" {
    local DB1 DB2
    DB1="${BATS_TEST_TMPDIR}/order-a.db"
    DB2="${BATS_TEST_TMPDIR}/order-b.db"
    "${SDLC_STATE}" --db "${DB1}" init >/dev/null
    "${SDLC_STATE}" --db "${DB2}" init >/dev/null

    # Use a fixed run-id so the metadata block matches across DBs.
    sqlite3 "${DB1}" "INSERT INTO runs(id, scope, mode, status, started_at) VALUES ('r-stable', 'epic-04', 'parallel', 'DONE', '2026-05-20 10:00:00');"
    sqlite3 "${DB2}" "INSERT INTO runs(id, scope, mode, status, started_at) VALUES ('r-stable', 'epic-04', 'parallel', 'DONE', '2026-05-20 10:00:00');"

    # Insert into DB1 in ascending order; DB2 in descending.
    for s in 4.2-A 4.2-B 4.2-C; do
        "${SDLC_STATE}" --db "${DB1}" story-upsert \
            r-stable "${s}" 04 "Story ${s}" P1 3 bash "feature/${s}" 1 DONE
    done
    for s in 4.2-C 4.2-B 4.2-A; do
        "${SDLC_STATE}" --db "${DB2}" story-upsert \
            r-stable "${s}" 04 "Story ${s}" P1 3 bash "feature/${s}" 1 DONE
    done

    local out1 out2
    out1="${BATS_TEST_TMPDIR}/order-a.md"
    out2="${BATS_TEST_TMPDIR}/order-b.md"
    "${SDLC_STATE}" --db "${DB1}" render >"${out1}"
    "${SDLC_STATE}" --db "${DB2}" render >"${out2}"
    diff "${out1}" "${out2}"
}

# ---------------------------------------------------------------------------
# --out: atomic file write. The temp file must not be left behind, and the
# destination must be created with the rendered content.
# ---------------------------------------------------------------------------

@test "render --out writes to the destination file atomically" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-OUT 04 "Out flag" P1 3 bash feature/4.2-OUT 1 DONE

    local dest="${BATS_TEST_TMPDIR}/out/progress.md"
    mkdir -p "$(dirname "${dest}")"
    run "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    [ "${status}" -eq 0 ]
    [ -f "${dest}" ]
    # No stale .tmp lying around.
    [ ! -f "${dest}.tmp" ]
    grep -q "## Epic-04 Build Log" "${dest}"
    grep -q "| 4.2-OUT | Out flag | DONE" "${dest}"
}

# ---------------------------------------------------------------------------
# Historical (pre-ledger) section must be preserved in the rendered output.
# The renderer includes a snapshot of pre-ledger build history so existing
# epic-01..epic-05 timelines survive the cut-over.
# ---------------------------------------------------------------------------

@test "render preserves the historical (pre-ledger) section verbatim" {
    [ -f "${HISTORICAL}" ]
    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # A signature marker from the historical content (epic-05 release notes).
    [[ "${output}" == *"Historical"* ]]
    # And we expect the historical marker to mention E2E_PASS as that is the
    # documented prior-state.
    [[ "${output}" == *"5.1-001"* ]]
}

# ---------------------------------------------------------------------------
# Title with embedded pipe characters must not break the table layout.
# Tables use `|` as the column separator — every TEXT value going into a cell
# must escape `|` to `\|` (the GFM-standard escape).
# ---------------------------------------------------------------------------

@test "render escapes pipe characters in titles to keep the table valid" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-PIPE 04 "Title with | pipe" P1 3 bash feature/4.2-PIPE 1 DONE

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # The pipe must be escaped — search for the backslash escape.
    [[ "${output}" == *"Title with \\| pipe"* ]]
}

# ---------------------------------------------------------------------------
# render-all: same output as the default render. Provided for callers that
# want to bootstrap a fresh file when .build-progress.md is missing.
# ---------------------------------------------------------------------------

@test "render-all produces the same output as render" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-ALL 04 "render-all parity" P1 3 bash feature/4.2-ALL 1 DONE

    local a b
    a="${BATS_TEST_TMPDIR}/r.md"
    b="${BATS_TEST_TMPDIR}/ra.md"
    "${SDLC_STATE}" --db "${DB}" render >"${a}"
    "${SDLC_STATE}" --db "${DB}" render-all >"${b}"
    diff "${a}" "${b}"
}

# ---------------------------------------------------------------------------
# Read-only: render must not modify the DB. Capture mtime before / after.
# ---------------------------------------------------------------------------

@test "render does not modify the database (read-only)" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-RO 04 "Read only" P1 3 bash feature/4.2-RO 1 DONE
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE

    # Capture file size and a strong checksum of the DB file before / after.
    local before after
    before=$(sha256sum "${DB}" 2>/dev/null | awk '{print $1}')
    if [ -z "${before}" ]; then
        before=$(shasum -a 256 "${DB}" | awk '{print $1}')
    fi
    "${SDLC_STATE}" --db "${DB}" render >/dev/null
    after=$(sha256sum "${DB}" 2>/dev/null | awk '{print $1}')
    if [ -z "${after}" ]; then
        after=$(shasum -a 256 "${DB}" | awk '{print $1}')
    fi
    [ "${before}" = "${after}" ]
}

# ---------------------------------------------------------------------------
# Hook forwarding: the emit hook must transparently forward render calls.
# ---------------------------------------------------------------------------

@test "sdlc-state-emit.sh forwards render --out to the renderer" {
    local run_id
    run_id=$(SDLC_STATE_DB="${DB}" "${EMIT_HOOK}" run-create epic-04 parallel)
    SDLC_STATE_DB="${DB}" "${EMIT_HOOK}" story-upsert \
        "${run_id}" 4.2-EMIT 04 "Via emit" P1 3 bash feature/4.2-EMIT 1 DONE
    local dest="${BATS_TEST_TMPDIR}/via-emit.md"
    SDLC_STATE_DB="${DB}" run "${EMIT_HOOK}" render --out "${dest}"
    [ "${status}" -eq 0 ]
    [ -f "${dest}" ]
    grep -q "| 4.2-EMIT | Via emit | DONE" "${dest}"
}

# ---------------------------------------------------------------------------
# Malformed DB (wrong magic bytes): render exits non-zero with a clear error.
# The renderer must never hang or silently succeed on a corrupt database.
# ---------------------------------------------------------------------------

@test "render with wrong magic bytes exits non-zero with a clear error" {
    local bad_db="${BATS_TEST_TMPDIR}/wrong-magic.db"
    printf 'NOTASQLITEFILE\n' > "${bad_db}"

    run "${SDLC_STATE}" --db "${bad_db}" render
    # sqlite3 returns non-zero when the file is not a valid database.
    [ "${status}" -ne 0 ]
    # The combined output+stderr must mention the corruption.
    [[ "${output}" == *"not a database"* ]] || [[ "${output}" == *"malformed"* ]] || \
        [[ "${output}" == *"Error"* ]]
}

# ---------------------------------------------------------------------------
# Truncated DB (valid magic bytes, truncated body): same contract as above.
# ---------------------------------------------------------------------------

@test "render with a truncated DB exits non-zero with a clear error" {
    # Build a valid DB in the setup tmpdir, then truncate a copy of it.
    local truncated_db="${BATS_TEST_TMPDIR}/truncated.db"
    # Copy only the first 100 bytes of a valid (but schema-less) sqlite DB.
    dd if="${DB}" bs=1 count=100 of="${truncated_db}" 2>/dev/null

    run "${SDLC_STATE}" --db "${truncated_db}" render
    [ "${status}" -ne 0 ]
    [[ "${output}" == *"malformed"* ]] || [[ "${output}" == *"not a database"* ]] || \
        [[ "${output}" == *"Error"* ]]
}

# ---------------------------------------------------------------------------
# Unwritable --out path: render exits non-zero and the original file is intact.
# The atomic write (tmp + rename) must never truncate the destination before
# it is ready to move the tmp into place.
# ---------------------------------------------------------------------------

@test "render --out to unwritable directory exits non-zero and leaves original intact" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-WRITE 04 "Write test" P1 3 bash feature/4.2-WRITE 1 DONE

    # Create a read-only directory and a known original file inside it.
    local ro_dir="${BATS_TEST_TMPDIR}/readonly"
    mkdir -p "${ro_dir}"
    local dest="${ro_dir}/progress.md"
    printf 'ORIGINAL\n' > "${dest}"
    chmod a-w "${ro_dir}"

    run "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    local rc="${status}"

    # Restore permissions so BATS cleanup can remove the dir.
    chmod 755 "${ro_dir}"

    # Must fail.
    [ "${rc}" -ne 0 ]
    # Original content must still be intact.
    grep -q "^ORIGINAL$" "${dest}"
}

# ---------------------------------------------------------------------------
# Large ledger: hundreds of stories complete in a reasonable time (<30 s)
# and produce deterministic output on repeated calls.
# ---------------------------------------------------------------------------

@test "render with a large ledger completes in under 30 seconds and is deterministic" {
    # Insert 5 runs x 40 stories = 200 stories across multiple epics.
    local r run_id s
    for r in 01 02 03 04 05; do
        run_id=$("${SDLC_STATE}" --db "${DB}" run-create "epic-${r}" parallel)
        for s in $(seq 1 40); do
            "${SDLC_STATE}" --db "${DB}" story-upsert \
                "${run_id}" "${r}-$(printf '%03d' "${s}")" "${r}" \
                "Story ${r}-$(printf '%03d' "${s}")" P1 3 bash \
                "feature/${r}-${s}" "${s}" DONE >/dev/null
        done
        "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE >/dev/null
    done

    # Time the render; bash `time` goes to stderr so capture wall time via date.
    local t0 t1
    t0=$(date +%s)
    "${SDLC_STATE}" --db "${DB}" render > "${BATS_TEST_TMPDIR}/large-1.md"
    t1=$(date +%s)
    local elapsed=$(( t1 - t0 ))
    [ "${elapsed}" -lt 30 ]

    # Determinism: second call must be byte-identical.
    "${SDLC_STATE}" --db "${DB}" render > "${BATS_TEST_TMPDIR}/large-2.md"
    diff "${BATS_TEST_TMPDIR}/large-1.md" "${BATS_TEST_TMPDIR}/large-2.md"
}

# ---------------------------------------------------------------------------
# NULL optional columns: pr_number NULL renders as "—", never literal "NULL".
# Tests COALESCE behaviour end-to-end through the renderer.
# ---------------------------------------------------------------------------

@test "render with NULL optional columns never emits literal NULL in output" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    # Insert directly via sqlite3 so we can force NULL on pr_number and branch.
    sqlite3 "${DB}" \
        "INSERT INTO stories(run_id, story_id, epic_id, title, status, branch, pr_number)
         VALUES ('${run_id}', '4.2-NULLPR', '04', 'PR is null', 'IN_PROGRESS', NULL, NULL);"

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # The word NULL must not appear in any table cell.
    [[ "${output}" != *"| NULL |"* ]]
    [[ "${output}" != *"| NULL"$'\n'* ]]
    # The null-pr row must still appear in the output.
    [[ "${output}" == *"4.2-NULLPR"* ]]
    # And the dash placeholder must be used.
    [[ "${output}" == *"— |"* ]]
}

# ---------------------------------------------------------------------------
# Backtick in titles: backticks are valid markdown inline code markers; they
# must pass through to the cell without being stripped or doubled.
# ---------------------------------------------------------------------------

@test "render preserves backtick characters in story titles" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    sqlite3 "${DB}" \
        "INSERT INTO stories(run_id, story_id, epic_id, title, status, branch)
         VALUES ('${run_id}', '4.2-BTICK', '04', 'Use \`cmd\` here', 'DONE', 'feature/test');"

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # Backtick-enclosed text must appear in the output (not stripped).
    [[ "${output}" == *'`cmd`'* ]]
}

# ---------------------------------------------------------------------------
# Multi-line titles: a newline inside a title value must collapse to a space
# so the markdown table stays on a single row.
# ---------------------------------------------------------------------------

@test "render collapses newlines in titles so the table row stays on one line" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    sqlite3 "${DB}" \
        "INSERT INTO stories(run_id, story_id, epic_id, title, status, branch)
         VALUES ('${run_id}', '4.2-NL', '04', 'Line1'||char(10)||'Line2', 'DONE', 'feature/test');"

    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    # The output must contain both words on the same line (joined by a space).
    [[ "${output}" == *"Line1 Line2"* ]]
    # And must NOT have "Line2" appearing as a standalone partial table row.
    # A partial row would look like "| Line2 | DONE |" — check it's absent.
    [[ "${output}" != *"| Line2 | DONE"* ]]
}

# ---------------------------------------------------------------------------
# render-all when historical snapshot is missing: degrades gracefully,
# emitting a valid document with no Historical section (not an error).
# ---------------------------------------------------------------------------

@test "render-all degrades gracefully when historical snapshot is absent" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-RA 04 "render-all no-hist" P1 3 bash feature/4.2-RA 1 DONE

    # Temporarily hide the historical snapshot from the repo root.
    local hist_path="${BATS_TEST_DIRNAME}/../docs/stories/.build-progress.historical.md"
    local hist_backup="${BATS_TEST_TMPDIR}/historical.md.bak"
    if [ -f "${hist_path}" ]; then
        mv "${hist_path}" "${hist_backup}"
    fi

    run "${SDLC_STATE}" --db "${DB}" render-all
    local rc="${status}"

    # Restore unconditionally so the teardown is always clean.
    if [ -f "${hist_backup}" ]; then
        mv "${hist_backup}" "${hist_path}"
    fi

    [ "${rc}" -eq 0 ]
    # Must still produce the main heading and E2E Gate section.
    [[ "${output}" == *"# Build Progress"* ]]
    [[ "${output}" == *"## E2E Gate"* ]]
    # Must NOT have the Historical heading because the file was absent.
    [[ "${output}" != *"## Historical (pre-ledger)"* ]]
}

# ---------------------------------------------------------------------------
# render-all when historical snapshot exists but is empty: still produces
# a structurally valid document (Historical section present but empty body).
# ---------------------------------------------------------------------------

@test "render-all with an empty historical snapshot produces valid output" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 4.2-RAE 04 "render-all empty-hist" P1 3 bash feature/4.2-RAE 1 DONE

    # Temporarily replace the historical snapshot with an empty file.
    local hist_path="${BATS_TEST_DIRNAME}/../docs/stories/.build-progress.historical.md"
    local hist_backup="${BATS_TEST_TMPDIR}/historical.md.bak"
    if [ -f "${hist_path}" ]; then
        cp "${hist_path}" "${hist_backup}"
        : > "${hist_path}"   # truncate to empty
    else
        touch "${hist_path}"
    fi

    run "${SDLC_STATE}" --db "${DB}" render-all
    local rc="${status}"

    # Restore unconditionally.
    if [ -f "${hist_backup}" ]; then
        mv "${hist_backup}" "${hist_path}"
    else
        rm -f "${hist_path}"
    fi

    [ "${rc}" -eq 0 ]
    [[ "${output}" == *"# Build Progress"* ]]
    [[ "${output}" == *"## Historical (pre-ledger)"* ]]
    [[ "${output}" == *"## E2E Gate"* ]]
}

# ---------------------------------------------------------------------------
# Atomicity under SIGKILL: killing the render mid-write must leave the
# destination file either in its original state or fully replaced —
# never a partial render. The .tmp side-file may be left behind (that is an
# acceptable artefact of SIGKILL) but the primary destination must be intact.
# ---------------------------------------------------------------------------

@test "SIGKILL during render --out leaves destination intact (never partial)" {
    # Populate a moderately-sized ledger so the render takes a little time.
    local run_id s
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-04 parallel)
    for s in $(seq 1 30); do
        "${SDLC_STATE}" --db "${DB}" story-upsert \
            "${run_id}" "4.2-K$(printf '%02d' "${s}")" 04 \
            "Kill story $(printf '%02d' "${s}")" P1 3 bash \
            "feature/k${s}" "${s}" DONE >/dev/null
    done
    "${SDLC_STATE}" --db "${DB}" run-update-status "${run_id}" DONE >/dev/null

    local dest="${BATS_TEST_TMPDIR}/atomic.md"
    local original_content="ORIGINAL_ATOMIC_CONTENT"
    printf '%s\n' "${original_content}" > "${dest}"

    # Launch render in the background and immediately kill it.
    "${SDLC_STATE}" --db "${DB}" render --out "${dest}" &
    local bg_pid=$!
    # Give it the briefest head-start so the .tmp open has likely occurred.
    sleep 0.05
    kill -9 "${bg_pid}" 2>/dev/null
    wait "${bg_pid}" 2>/dev/null || true

    # The destination must contain EITHER the original content (render was
    # killed before mv completed) OR the full new render (mv was atomic and
    # already committed). It must NEVER be empty or partially written.
    local dest_content
    dest_content=$(cat "${dest}")
    # Must not be empty.
    [ -n "${dest_content}" ]
    # Must be either the original marker or a valid render (starts with "# Build Progress").
    [[ "${dest_content}" == "${original_content}" ]] || \
        [[ "${dest_content}" == *"# Build Progress"* ]]
}

# ---------------------------------------------------------------------------
# Story 12.2-001: non-destructive renderer.
#
# The auto-generated portion of `.build-progress.md` is fenced inside a
# managed-region marker pair. Anything OUTSIDE that pair (hand-maintained
# history, epics tracked via the markdown workflow, notes) must survive a
# re-render. Inside the pair is regenerated from the SQLite ledger and is
# deterministic / idempotent.
# ---------------------------------------------------------------------------

@test "render wraps the auto-generated section in managed-region markers" {
    run "${SDLC_STATE}" --db "${DB}" render
    [ "${status}" -eq 0 ]
    [[ "${output}" == *"BEGIN SDLC LEDGER"* ]]
    [[ "${output}" == *"END SDLC LEDGER"* ]]
}

@test "render --out preserves non-ledger content outside the managed markers" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-12 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 12.2-NEW 12 "Fresh ledger story" P1 3 bash feature/12.2-NEW 1 DONE

    # A file that already carries a managed region plus hand-maintained
    # history both BEFORE and AFTER the markers.
    local dest="${BATS_TEST_TMPDIR}/preserve.md"
    cat > "${dest}" <<'EOF'
# Build Progress

## Epic-99 Hand-Maintained Log

| Story ID | Title | Status |
|----------|-------|--------|
| 99.1 | Done outside the ledger | DONE |

<!-- BEGIN SDLC LEDGER (auto-generated by sdlc-state render — do not edit this region) -->
STALE MANAGED CONTENT THAT MUST BE REPLACED
<!-- END SDLC LEDGER -->

## Footer notes maintained by hand

Keep this paragraph.
EOF

    run "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    [ "${status}" -eq 0 ]

    # Out-of-band history (before AND after the markers) survives verbatim.
    grep -q "## Epic-99 Hand-Maintained Log" "${dest}"
    grep -q "99.1 | Done outside the ledger | DONE" "${dest}"
    grep -q "## Footer notes maintained by hand" "${dest}"
    grep -q "Keep this paragraph." "${dest}"

    # Managed region was regenerated: stale placeholder gone, ledger story in.
    ! grep -q "STALE MANAGED CONTENT" "${dest}"
    grep -q "12.2-NEW | Fresh ledger story | DONE" "${dest}"

    # Exactly one marker pair — splice must not nest or duplicate the region.
    [ "$(grep -c 'BEGIN SDLC LEDGER' "${dest}")" -eq 1 ]
    [ "$(grep -c 'END SDLC LEDGER' "${dest}")" -eq 1 ]
}

@test "render --out preserves a legacy markerless file's content" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-12 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 12.2-LEG 12 "Legacy merge" P1 3 bash feature/12.2-LEG 1 DONE

    # A pre-existing file with NO markers — pure hand-maintained history.
    local dest="${BATS_TEST_TMPDIR}/legacy.md"
    cat > "${dest}" <<'EOF'
# Build Progress

## Epic-05 Build Log

| 5.1-001 | Conventional Commits | DONE |
EOF

    run "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    [ "${status}" -eq 0 ]

    # The hand-maintained content must NOT be clobbered.
    grep -q "## Epic-05 Build Log" "${dest}"
    grep -q "5.1-001 | Conventional Commits | DONE" "${dest}"
    # And a managed region was introduced so future renders are idempotent.
    grep -q "BEGIN SDLC LEDGER" "${dest}"
    grep -q "12.2-LEG | Legacy merge | DONE" "${dest}"
}

@test "render --out is idempotent across repeated renders" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-12 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 12.2-IDEM 12 "Idempotent merge" P1 3 bash feature/12.2-IDEM 1 DONE

    local dest="${BATS_TEST_TMPDIR}/idem.md"
    cat > "${dest}" <<'EOF'
# Build Progress

## Epic-99 Hand-Maintained Log

Preserve me.

<!-- BEGIN SDLC LEDGER (auto-generated by sdlc-state render — do not edit this region) -->
old
<!-- END SDLC LEDGER -->
EOF

    "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    cp "${dest}" "${BATS_TEST_TMPDIR}/idem-1.md"
    "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    cp "${dest}" "${BATS_TEST_TMPDIR}/idem-2.md"

    # Re-rendering the same ledger state must be byte-identical (no drift,
    # no duplicated markers, no dropped hand-maintained content).
    diff "${BATS_TEST_TMPDIR}/idem-1.md" "${BATS_TEST_TMPDIR}/idem-2.md"
    [ "$(grep -c 'BEGIN SDLC LEDGER' "${dest}")" -eq 1 ]
    grep -q "Preserve me." "${dest}"
}

@test "render --out greenfield (no prior file) writes a marked document" {
    local run_id
    run_id=$("${SDLC_STATE}" --db "${DB}" run-create epic-12 parallel)
    "${SDLC_STATE}" --db "${DB}" story-upsert \
        "${run_id}" 12.2-GF 12 "Greenfield" P1 3 bash feature/12.2-GF 1 DONE

    local dest="${BATS_TEST_TMPDIR}/greenfield.md"
    run "${SDLC_STATE}" --db "${DB}" render --out "${dest}"
    [ "${status}" -eq 0 ]
    [ -f "${dest}" ]
    # Greenfield output is the full auto-generated document, fenced in markers.
    grep -q "BEGIN SDLC LEDGER" "${dest}"
    grep -q "END SDLC LEDGER" "${dest}"
    grep -q "# Build Progress" "${dest}"
    grep -q "## E2E Gate" "${dest}"
    grep -q "12.2-GF | Greenfield | DONE" "${dest}"
}
