{
  "ignorePatterns": [
    { "pattern": "^mailto:" },
    { "pattern": "^https?://localhost" },
    { "pattern": "^https?://127\\.0\\.0\\.1" },
    { "pattern": "^https?://([^/]+\\.)?example\\.(com|org|net)" },
    { "comment": "Planned deliverable of Epic-06, not yet created; forward-referenced by epic planning docs.", "pattern": "(^|/)docs/onboarding\\.md$" }
  ],
  "httpHeaders": [
    {
      "urls": ["https://github.com", "https://raw.githubusercontent.com"],
